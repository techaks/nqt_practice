 (2,1) (5,4)

#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
   
    cin >> n;

    int arr[n][2];

    
    for(int i = 0; i < n; i++) {
        cin >> arr[i][0] >> arr[i][1];
    }

    unordered_map<int, int> mp;

    cout << "Symmetric Pairs are:\n";

    for(int i = 0; i < n; i++) {
        int first = arr[i][0];
        int second = arr[i][1];

        // check reverse pair exists
        if(mp.find(second) != mp.end() && mp[second] == first) {
            cout << "(" << second << "," << first << ") ";
        } else {
            mp[first] = second;
        }
    }

    return 0;
}


